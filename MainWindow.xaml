<Window x:Class="FileConverter.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:FileConverter"
        mc:Ignorable="d"
        Title="File Converter" Height="640" Width="720" MinWidth="560" MinHeight="540">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,16">
            <TextBlock Text="File Converter" Style="{StaticResource H1}"/>
            <TextBlock Text="Native Windows · powered by ffmpeg" Style="{StaticResource Subtitle}"/>
        </StackPanel>

        <TabControl Grid.Row="1" Grid.RowSpan="2" x:Name="Tabs">
            <!-- VIDEO -->
            <TabItem Header="Video">
                <Grid Margin="0,16,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Border Grid.Row="0" Style="{StaticResource DropZone}"
                            x:Name="VideoDropZone" AllowDrop="True"
                            DragEnter="DropZone_DragEnter" DragLeave="DropZone_DragLeave" Drop="VideoDrop"
                            MouseLeftButtonUp="VideoBrowse_Click">
                        <Grid>
                            <StackPanel x:Name="VideoEmpty" HorizontalAlignment="Center" VerticalAlignment="Center">
                                <TextBlock Text="Drop a video here" FontSize="15" FontWeight="SemiBold"
                                           HorizontalAlignment="Center"/>
                                <TextBlock Text="or click to choose · MKV, MP4, WebM, MOV, AVI, FLV…"
                                           Foreground="{StaticResource MutedBrush}" FontSize="12"
                                           HorizontalAlignment="Center" Margin="0,6,0,0"/>
                            </StackPanel>
                            <ListBox x:Name="VideoFiles" Visibility="Collapsed" BorderThickness="0"
                                     Background="Transparent"/>
                        </Grid>
                    </Border>

                    <Border Grid.Row="1" Style="{StaticResource Card}" Margin="0,16,0,0">
                        <StackPanel>
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Convert to" Style="{StaticResource LabelText}" Margin="0,0,12,0"/>
                                <ComboBox Grid.Column="1" x:Name="VideoFormat" HorizontalAlignment="Left">
                                    <ComboBoxItem Content="MP4 (H.264 / AAC)" Tag="mp4" IsSelected="True"/>
                                    <ComboBoxItem Content="WebM (VP9 / Opus)" Tag="webm"/>
                                    <ComboBoxItem Content="MKV (Matroska)" Tag="mkv"/>
                                    <ComboBoxItem Content="MOV (QuickTime)" Tag="mov"/>
                                    <ComboBoxItem Content="GIF (animated)" Tag="gif"/>
                                </ComboBox>
                            </Grid>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Button Grid.Column="0" Style="{StaticResource PrimaryButton}"
                                        Content="Convert" x:Name="VideoConvert" Click="VideoConvert_Click"
                                        IsEnabled="False"/>
                                <Button Grid.Column="1" Style="{StaticResource GhostButton}"
                                        Content="Clear" Margin="8,0,0,0" Click="VideoClear_Click"/>
                            </Grid>
                            <ProgressBar x:Name="VideoProgress" Margin="0,12,0,0" Value="0" Maximum="1" Visibility="Collapsed"/>
                            <TextBlock x:Name="VideoStatus" Foreground="{StaticResource MutedBrush}"
                                       FontSize="12" Margin="0,8,0,0" TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </TabItem>

            <!-- AUDIO -->
            <TabItem Header="Audio">
                <Grid Margin="0,16,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Border Grid.Row="0" Style="{StaticResource DropZone}"
                            x:Name="AudioDropZone" AllowDrop="True"
                            DragEnter="DropZone_DragEnter" DragLeave="DropZone_DragLeave" Drop="AudioDrop"
                            MouseLeftButtonUp="AudioBrowse_Click">
                        <Grid>
                            <StackPanel x:Name="AudioEmpty" HorizontalAlignment="Center" VerticalAlignment="Center">
                                <TextBlock Text="Drop audio files here" FontSize="15" FontWeight="SemiBold"
                                           HorizontalAlignment="Center"/>
                                <TextBlock Text="or click to choose · MP3, WAV, FLAC, OGG, M4A, OPUS…"
                                           Foreground="{StaticResource MutedBrush}" FontSize="12"
                                           HorizontalAlignment="Center" Margin="0,6,0,0"/>
                            </StackPanel>
                            <ListBox x:Name="AudioFiles" Visibility="Collapsed" BorderThickness="0"
                                     Background="Transparent"/>
                        </Grid>
                    </Border>

                    <Border Grid.Row="1" Style="{StaticResource Card}" Margin="0,16,0,0">
                        <StackPanel>
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Convert to" Style="{StaticResource LabelText}" Margin="0,0,12,0"/>
                                <ComboBox Grid.Column="1" x:Name="AudioFormat" HorizontalAlignment="Left"
                                          SelectionChanged="AudioFormat_Changed">
                                    <ComboBoxItem Content="MP3" Tag="mp3" IsSelected="True"/>
                                    <ComboBoxItem Content="WAV (PCM)" Tag="wav"/>
                                    <ComboBoxItem Content="FLAC (lossless)" Tag="flac"/>
                                    <ComboBoxItem Content="OGG (Vorbis)" Tag="ogg"/>
                                    <ComboBoxItem Content="M4A (AAC)" Tag="m4a"/>
                                    <ComboBoxItem Content="OPUS" Tag="opus"/>
                                </ComboBox>
                                <TextBlock Grid.Column="2" Text="Bitrate" Style="{StaticResource LabelText}" Margin="16,0,12,0"
                                           x:Name="AudioBitrateLabel"/>
                                <ComboBox Grid.Column="3" x:Name="AudioBitrate" MinWidth="100">
                                    <ComboBoxItem Content="96 kbps" Tag="96k"/>
                                    <ComboBoxItem Content="128 kbps" Tag="128k"/>
                                    <ComboBoxItem Content="192 kbps" Tag="192k" IsSelected="True"/>
                                    <ComboBoxItem Content="256 kbps" Tag="256k"/>
                                    <ComboBoxItem Content="320 kbps" Tag="320k"/>
                                </ComboBox>
                            </Grid>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Button Grid.Column="0" Style="{StaticResource PrimaryButton}"
                                        Content="Convert" x:Name="AudioConvert" Click="AudioConvert_Click"
                                        IsEnabled="False"/>
                                <Button Grid.Column="1" Style="{StaticResource GhostButton}"
                                        Content="Clear" Margin="8,0,0,0" Click="AudioClear_Click"/>
                            </Grid>
                            <ProgressBar x:Name="AudioProgress" Margin="0,12,0,0" Value="0" Maximum="1" Visibility="Collapsed"/>
                            <TextBlock x:Name="AudioStatus" Foreground="{StaticResource MutedBrush}"
                                       FontSize="12" Margin="0,8,0,0" TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </TabItem>

            <!-- IMAGE -->
            <TabItem Header="Image">
                <Grid Margin="0,16,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Border Grid.Row="0" Style="{StaticResource DropZone}"
                            x:Name="ImageDropZone" AllowDrop="True"
                            DragEnter="DropZone_DragEnter" DragLeave="DropZone_DragLeave" Drop="ImageDrop"
                            MouseLeftButtonUp="ImageBrowse_Click">
                        <Grid>
                            <StackPanel x:Name="ImageEmpty" HorizontalAlignment="Center" VerticalAlignment="Center">
                                <TextBlock Text="Drop images here" FontSize="15" FontWeight="SemiBold"
                                           HorizontalAlignment="Center"/>
                                <TextBlock Text="or click to choose · PNG, JPEG, WebP, GIF, BMP, TIFF…"
                                           Foreground="{StaticResource MutedBrush}" FontSize="12"
                                           HorizontalAlignment="Center" Margin="0,6,0,0"/>
                            </StackPanel>
                            <ListBox x:Name="ImageFiles" Visibility="Collapsed" BorderThickness="0"
                                     Background="Transparent"/>
                        </Grid>
                    </Border>

                    <Border Grid.Row="1" Style="{StaticResource Card}" Margin="0,16,0,0">
                        <StackPanel>
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Convert to" Style="{StaticResource LabelText}" Margin="0,0,12,0"/>
                                <ComboBox Grid.Column="1" x:Name="ImageFormat" HorizontalAlignment="Left"
                                          SelectionChanged="ImageFormat_Changed">
                                    <ComboBoxItem Content="PNG (lossless)" Tag="png"/>
                                    <ComboBoxItem Content="JPEG" Tag="jpg" IsSelected="True"/>
                                    <ComboBoxItem Content="WebP" Tag="webp"/>
                                    <ComboBoxItem Content="BMP" Tag="bmp"/>
                                    <ComboBoxItem Content="TIFF" Tag="tiff"/>
                                </ComboBox>
                                <TextBlock Grid.Column="2" Text="Quality" Style="{StaticResource LabelText}" Margin="16,0,12,0"
                                           x:Name="ImageQualityLabel"/>
                                <ComboBox Grid.Column="3" x:Name="ImageQuality" MinWidth="80">
                                    <ComboBoxItem Content="60" Tag="60"/>
                                    <ComboBoxItem Content="75" Tag="75"/>
                                    <ComboBoxItem Content="85" Tag="85" IsSelected="True"/>
                                    <ComboBoxItem Content="92" Tag="92"/>
                                    <ComboBoxItem Content="100" Tag="100"/>
                                </ComboBox>
                            </Grid>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Button Grid.Column="0" Style="{StaticResource PrimaryButton}"
                                        Content="Convert" x:Name="ImageConvert" Click="ImageConvert_Click"
                                        IsEnabled="False"/>
                                <Button Grid.Column="1" Style="{StaticResource GhostButton}"
                                        Content="Clear" Margin="8,0,0,0" Click="ImageClear_Click"/>
                            </Grid>
                            <ProgressBar x:Name="ImageProgress" Margin="0,12,0,0" Value="0" Maximum="1" Visibility="Collapsed"/>
                            <TextBlock x:Name="ImageStatus" Foreground="{StaticResource MutedBrush}"
                                       FontSize="12" Margin="0,8,0,0" TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </TabItem>
        </TabControl>

        <TextBlock Grid.Row="3" x:Name="GlobalStatus" Margin="0,16,0,0"
                   Foreground="{StaticResource MutedBrush}" FontSize="11"/>
    </Grid>
</Window>
